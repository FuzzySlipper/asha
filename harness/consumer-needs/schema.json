{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asha.dev/schemas/consumer-needs.v1.json",
  "title": "ASHA consumer needs manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "consumer", "requirements"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "consumer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 }
      }
    },
    "requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "provider", "selector", "delivery"],
      "properties": {
        "type": { "$ref": "#/$defs/refs" },
        "provider": { "$ref": "#/$defs/refs" },
        "selector": { "$ref": "#/$defs/refs" },
        "delivery": { "$ref": "#/$defs/refs" }
      }
    },
    "refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "quota": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxItems": { "type": "integer", "minimum": 1 },
        "maxPayloadBytes": { "type": "integer", "minimum": 1 },
        "maxDeliveries": { "type": "integer", "minimum": 1 }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prefab": { "type": "integer", "minimum": 1 },
        "role": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "identity", "requiredLevel", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": [
            "typescriptPackage", "runtimeOperation", "runtimeReadout",
            "generatedType", "projectionChannel", "conformanceEntrypoint",
            "rustCrate", "gameplayModule", "gameplayEventPublish",
            "gameplayEventSubscribe", "gameplayInvocation", "gameplayRead",
            "gameplayProposal", "gameplayOwner", "gameplayStateSchema",
            "gameplayFactSchema", "gameplayBindingSchema", "bootstrapAdapter",
            "projectBundleArtifact", "prefabPart", "serviceQuery"
          ]
        },
        "identity": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "symbols": { "$ref": "#/$defs/refs" },
        "fields": { "$ref": "#/$defs/refs" },
        "selectors": { "$ref": "#/$defs/refs" },
        "values": { "$ref": "#/$defs/refs" },
        "quota": { "$ref": "#/$defs/quota" },
        "ordering": { "type": "string", "minLength": 1 },
        "target": { "$ref": "#/$defs/target" },
        "artifactRole": { "type": "string", "minLength": 1 },
        "requiredLevel": { "enum": ["type", "provider", "selector", "delivery"] },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    }
  }
}
